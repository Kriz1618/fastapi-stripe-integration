# =============================================================================
# FastAPI Stripe Integration - Environment Configuration
# =============================================================================

# Application Configuration
DEBUG=True
ENVIRONMENT=development
SECRET_KEY=your-super-secret-key-change-in-production

# JWT Configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database Configuration
DATABASE_URL=sqlite:///./data/database.db
# For PostgreSQL: postgresql://user:password@localhost/dbname

# Stripe Configuration
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Webhook Configuration
# Get this from: https://dashboard.stripe.com/webhooks
# After creating webhook endpoint: https://your-domain.com/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# URLs Configuration
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000

# Subscription Plans (Price IDs from Stripe)
# Create products in Stripe Dashboard and copy the Price IDs here
# Price IDs start with "price_" (NOT product IDs that start with "prod_")
STRIPE_BASIC_PRICE_ID=price_your_basic_plan_price_id
STRIPE_PRO_PRICE_ID=price_your_pro_plan_price_id
STRIPE_PREMIUM_PRICE_ID=price_your_premium_plan_price_id

